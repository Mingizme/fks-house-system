# Lấy 2 giá trị này trong Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Dùng khi chạy script tạo tài khoản admin đầu tiên (server-side only, KHÔNG public)
# Lấy trong Project Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Gemini API server-side only, KHÔNG public
GEMINI_API_KEY=your_google_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash
